{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "moduleResolution": "node16",
    "rootDir": "src",
    "outDir": "dist",

    "types": ["jest", "node"],

    "strict": true,
    "esModuleInterop": true,

    "skipLibCheck": true,
    "sourceMap": true
  },
  "exclude": ["tests", "node_modules"]
}
